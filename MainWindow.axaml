<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        xmlns:local="clr-namespace:openwalls"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="openwalls.MainWindow"
        Title="openwalls"
        SystemDecorations="None"
        WindowState="Maximized"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False">
    
    <Grid>
        <!-- Layer 0: Solid Color -->
        <Border x:Name="ColorLayer" IsVisible="False" Background="Black"/>

        <!-- Layer 1: Solid Background (Fallback) -->
        <Border x:Name="GradientLayer" IsVisible="True" Background="Black"/>

        <!-- Layer 1.5: Zen Clock HUD -->
        <Grid x:Name="ClockLayer" IsVisible="False">
            <Image x:Name="ClockBackground" Stretch="UniformToFill" />
            <Border Background="Black" Opacity="0.2" /> <!-- Subtle darken for HUD readability -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,150">
                <TextBlock x:Name="ClockTime" Text="00:00" FontSize="120" FontWeight="ExtraBold" Foreground="White" LetterSpacing="5" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="30" Opacity="0.8" Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="ClockDate" Text="MONDAY, JANUARY 1" FontSize="28" FontWeight="Light" Foreground="White" LetterSpacing="12" HorizontalAlignment="Center" Margin="0,-20,0,0" Opacity="0.8">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.6" Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Layer 2: Image -->
        <Image x:Name="ImageLayer" Stretch="UniformToFill" IsVisible="False" Opacity="0"/>

        <!-- Layer 3: Video -->
        <vlc:VideoView x:Name="VideoLayer" IsVisible="False" Opacity="0"/>

        <!-- Layer 4: Procedural C# Animations -->
        <local:ProceduralCanvas x:Name="ProceduralLayer" IsVisible="False"/>

        <!-- Centered Label (Only if no content) -->
        <StackPanel x:Name="FallbackText" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5" IsVisible="True">
            <TextBlock Text="OPENWALLS" FontSize="72" FontWeight="ExtraBold" Foreground="White" LetterSpacing="10" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.5" Color="Black" />
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
