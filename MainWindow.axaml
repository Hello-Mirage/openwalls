<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        xmlns:local="clr-namespace:openwalls"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="openwalls.MainWindow"
        Title="openwalls"
        SystemDecorations="None"
        WindowState="Maximized"
        Background="Transparent"
        Topmost="False"
        ShowInTaskbar="False"
        PointerPressed="OnPointerPressed">

    <Window.ContextMenu>
        <ContextMenu x:Name="MainContextMenu">
            <MenuItem Header="Edit Clock Settings" Click="OnEditClockClick" x:Name="EditClockMenuItem"/>
            <Separator/>
            <MenuItem Header="Exit" Click="OnExitClick"/>
        </ContextMenu>
    </Window.ContextMenu>
    
    <Grid x:Name="RootGrid" Background="Transparent">
        <!-- Layer 0: Solid Color -->
        <Border x:Name="ColorLayer" IsVisible="False" Background="Black"/>

        <!-- Layer 1: Solid Background (Fallback) -->
        <Border x:Name="GradientLayer" IsVisible="True" Background="Black"/>

        <!-- Layer 2: Image -->
        <Image x:Name="ImageLayer" Stretch="UniformToFill" IsVisible="False" Opacity="0"/>

        <!-- Layer 3: Video -->
        <vlc:VideoView x:Name="VideoLayer" IsVisible="False" Opacity="0"/>

        <!-- Layer 4: Procedural C# Animations -->
        <local:ProceduralCanvas x:Name="ProceduralLayer" IsVisible="False"/>

        <!-- Layer 5: Zen Clock Background (The image/video backup for the clock) -->
        <Grid x:Name="ClockBackdropLayer" IsVisible="False">
            <Image x:Name="ClockBackground" Stretch="UniformToFill" />
            <Border Background="Black" Opacity="0.2" /> 
        </Grid>

        <!-- Centered Label (Only if no content) -->
        <StackPanel x:Name="FallbackText" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5" IsVisible="True" Spacing="20">
            <Image Width="120" Height="120" HorizontalAlignment="Center">
                <Image.Source>
                    <SvgImage Source="avares://openwalls/assets/openwalls_logo.svg" />
                </Image.Source>
                <Image.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.8" Color="#0D4F5C" />
                </Image.Effect>
            </Image>
            <TextBlock Text="OPENWALLS" FontSize="72" FontWeight="ExtraBold" Foreground="White" LetterSpacing="10" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.5" Color="Black" />
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <!-- Layer 7: Optimization Progress HUD (Bottom) -->
        <Border x:Name="OptimizationStatusHUD" 
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Stretch" 
                Height="60" 
                Background="#AA000000" 
                IsVisible="False">
            <Grid ColumnDefinitions="Auto, *, Auto" Margin="30, 0">
                <TextBlock x:Name="OptimizationStatusText" 
                           VerticalAlignment="Center" 
                           Foreground="White" 
                           FontSize="14" 
                           FontWeight="Medium"
                           Text="Optimizing Video for GPU Acceleration..."/>
                
                <ProgressBar x:Name="OptimizationProgressBar" 
                             Grid.Column="1" 
                             Margin="20, 0" 
                             Height="4" 
                             Minimum="0" 
                             Maximum="100" 
                             Value="0"
                             Foreground="#00ccff"
                             Background="#44ffffff"/>

                <TextBlock x:Name="OptimizationProgressPercent" 
                           Grid.Column="2" 
                           VerticalAlignment="Center" 
                           Foreground="White" 
                           FontSize="14" 
                           Width="50"
                           TextAlignment="Right"
                           Text="0%"/>
            </Grid>
        </Border>
    </Grid>
</Window>
