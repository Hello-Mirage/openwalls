<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:openwalls"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="openwalls.SettingsWindow"
        Title="Openwalls Dashboard"
        Width="920" Height="680"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica, AcrylicBlur"
        Background="Transparent"
        FontFamily="Inter, Roboto, sans-serif"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Window.Resources>
        <local:ActiveColorConverter x:Key="ActiveColorConverter"/>
        <local:ThumbnailConverter x:Key="ThumbnailConverter"/>
        <!-- Fluent Icons -->
        <StreamGeometry x:Key="library_regular">M12,2A10,10,0,1,0,22,12,10.011,10.011,0,0,0,12,2Zm0,18a8,8,0,1,1,8-8A8.009,8.009,0,0,1,12,20ZM11,7h2v6H11Zm0,8h2v2H11Z</StreamGeometry>
        <StreamGeometry x:Key="market_regular">M12,2L2,7v10l10,5 10-5V7L12,2zm0,2.18L19.34,7.5 12,10.82 4.66,7.5 12,4.18zM4,9.27l7,3.18v7.28l-7-3.5V9.27zm9,10.46v-7.28l7-3.18v7.5l-7,2.96z</StreamGeometry>
    </Window.Resources>

    <Grid RowDefinitions="Auto, *" Background="{StaticResource BaseBlackBrush}">
        <!-- Title Bar Drag Handle -->
        <Border Grid.Row="0" Height="32" Background="Transparent" IsHitTestVisible="True" PointerPressed="DragStrip_PointerPressed"/>

        <Grid Grid.Row="1" ColumnDefinitions="64, *">
            <!-- Phase 2: Sidebar (The Rail) -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceLowBrush}" ZIndex="50">
                <Grid RowDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Row="0" Margin="0,20,0,30" Spacing="0" HorizontalAlignment="Center">
                        <Image Width="24" Height="24">
                            <Image.Source>
                                <SvgImage Source="avares://openwalls/assets/openwalls_logo.svg" />
                            </Image.Source>
                        </Image>
                    </StackPanel>

                    <ListBox x:Name="NavList" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="NavList_SelectionChanged">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0,15"/>
                                <Setter Property="Margin" Value="10,5"/>
                                <Setter Property="CornerRadius" Value="999"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="{StaticResource ElectricLimeBrush}"/>
                                <Setter Property="RenderTransform" Value="rotate(-2deg) scale(1.1)"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected PathIcon">
                                <Setter Property="Foreground" Value="{StaticResource BaseBlackBrush}"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover:not(:selected)">
                                <Setter Property="Background" Value="#11ffffff"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBoxItem IsSelected="True" ToolTip.Tip="My Library">
                            <PathIcon Data="{StaticResource library_regular}" Width="18" Height="18" Foreground="{StaticResource OnSurfaceVariant}"/>
                        </ListBoxItem>
                        <ListBoxItem ToolTip.Tip="OWMarketplace">
                            <PathIcon Data="{StaticResource market_regular}" Width="18" Height="18" Foreground="{StaticResource OnSurfaceVariant}"/>
                        </ListBoxItem>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,20" Spacing="15" HorizontalAlignment="Center">
                         <Button Classes="Pill" Width="40" Height="40" Padding="0" Background="{StaticResource ElectricLimeBrush}" Click="AddNew_Click" ToolTip.Tip="Add New Wallpaper">
                            <TextBlock Text="+" FontSize="20" Foreground="{StaticResource BaseBlackBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                         </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Stage -->
            <Grid Grid.Column="1" Background="{StaticResource BaseBlackBrush}">
                <!-- Background Grain Overlay -->
                <Panel IsHitTestVisible="False" Opacity="0.03">
                    <!-- Texture will be loaded here -->
                </Panel>

                <!-- Floating TopBar -->
                <Border VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="30,20" Height="48" ZIndex="100">
                    <Grid ColumnDefinitions="*, Auto">
                        <!-- Search Pill -->
                        <Border Grid.Column="1" Background="{StaticResource SurfaceMidBrush}" CornerRadius="24" Width="260" Padding="15,0">
                            <Grid ColumnDefinitions="Auto, *">
                                <PathIcon Data="M11,19A8,8 0 0,1 3,11A8,8 0 0,1 11,3A8,8 0 0,1 19,11A8,8 0 0,1 11,19M11,5A6,6 0 0,0 5,11A6,6 0 0,0 11,17A6,6 0 0,0 17,11A6,6 0 0,0 11,5M23,21.5L20.5,19L19,20.5L21.5,23L23,21.5Z" 
                                          Width="14" Height="14" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Watermark="Search visuals..." Background="Transparent" BorderThickness="0" 
                                         VerticalContentAlignment="Center" FontSize="12" FontFamily="{StaticResource BeVietnam}">
                                    <TextBox.Styles>
                                        <Style Selector="TextBox:focus /template/ Border#PART_Indicator">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </Style>
                                    </TextBox.Styles>
                                </TextBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Main Content Scroll Area -->
                <ScrollViewer Margin="0,80,0,0">
                    <Grid>
                        <!-- My Library View -->
                        <Grid x:Name="LibraryView" RowDefinitions="Auto, *" Margin="30,0" IsVisible="True">
                            <StackPanel Grid.Row="0" Margin="0,10,0,30">
                                <TextBlock Text="My Library" Classes="Headline" FontSize="48" Foreground="White"/>
                                <TextBlock Text="Your curated collection of kinetic canvases." Classes="Body" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}"/>
                            </StackPanel>
                            
                            <ItemsControl Grid.Row="1" x:Name="LibraryItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="-10"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="local:WallpaperPreset">
                                        <Button Classes="LofiCard" Margin="10" Padding="0" Background="Transparent" BorderThickness="0" Click="Preset_Click">
                                            <Panel>
                                                <Border Width="240" Background="{StaticResource SurfaceLowBrush}" CornerRadius="32" ClipToBounds="True">
                                                    <Grid RowDefinitions="*, Auto">
                                                        <Panel Grid.Row="0" Height="300">
                                                            <Image Stretch="UniformToFill">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource ThumbnailConverter}">
                                                                        <Binding Path="." />
                                                                        <Binding Path="ThumbnailPath" />
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Panel>
                                                        <Border Grid.Row="1" Padding="20,15,20,20">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" Classes="Headline" FontSize="18" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Type}" Classes="Body" FontSize="11" Foreground="{StaticResource OnSurfaceVariant}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <!-- Active Badge -->
                                                <Border IsVisible="{Binding IsActive}" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15" 
                                                        Background="{StaticResource ElectricLimeBrush}" CornerRadius="20" Padding="12,4">
                                                    <TextBlock Text="ACTIVE" FontFamily="{StaticResource SpaceGrotesk}" FontWeight="Black" FontSize="10" Foreground="{StaticResource BaseBlackBrush}" FontStyle="Italic"/>
                                                </Border>
                                            </Panel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <!-- OWMarketplace View -->
                        <Grid x:Name="MarketplaceView" RowDefinitions="Auto, *" Margin="30,0" IsVisible="False">
                            <StackPanel Grid.Row="0" Margin="0,10,0,40">
                                <TextBlock Text="Discover" Classes="Headline" FontSize="48" Foreground="White"/>
                                <TextBlock Text="The latest community drops for your studio." Classes="Body" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Spacing="40">
                                <!-- Hero Display -->
                                <Border Height="280" CornerRadius="32" ClipToBounds="True">
                                    <Panel>
                                        <Image Source="assets/samurai-warrior-observing-village-moonlight.jpg" Stretch="UniformToFill" Opacity="0.5"/>
                                        <Border>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                                    <GradientStop Offset="0.3" Color="Transparent"/>
                                                    <GradientStop Offset="1" Color="{StaticResource BaseBlack}"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Bottom" Margin="30" Spacing="5">
                                            <Border Background="{StaticResource ElectricLimeBrush}" CornerRadius="99" HorizontalAlignment="Left" Padding="10,4">
                                                <TextBlock Text="FEATURED" FontFamily="{StaticResource SpaceGrotesk}" FontSize="10" FontWeight="Black" Foreground="{StaticResource BaseBlackBrush}"/>
                                            </Border>
                                            <TextBlock Text="The Samurai Series" Classes="Headline" FontSize="36" Foreground="White" />
                                            <TextBlock Text="Cinematic HUDs by Mirage Studio" Classes="Body" FontSize="14" Foreground="{StaticResource OnSurfaceVariant}"/>
                                        </StackPanel>
                                    </Panel>
                                </Border>

                                <StackPanel VerticalAlignment="Center" Margin="0,60,0,0" Spacing="30">
                                    <PathIcon Data="{StaticResource market_regular}" Width="64" Height="64" Foreground="{StaticResource SurfaceMidBrush}"/>
                                    <TextBlock Text="LABS OPTIMIZATION IN PROGRESS" Classes="Headline" FontSize="14" Foreground="{StaticResource SurfaceMidBrush}" HorizontalAlignment="Center" LetterSpacing="4"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.LofiCard">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="32"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.4" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.LofiCard:pointerover">
            <Setter Property="RenderTransform" Value="rotate(1.5deg) scale(1.02)"/>
            <Setter Property="ZIndex" Value="10"/>
        </Style>
        <!-- Fix: Override Button Chrome/Template backgrounds -->
        <Style Selector="Button.LofiCard /template/ ContentPresenter#PART_ContentPresenter">
             <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.LofiCard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
             <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.LofiCard:pointerover Border">
             <Setter Property="BoxShadow" Value="0 10 40 0 #22CCFF00"/>
        </Style>
        
        <Style Selector="Button.Pill:pointerover">
            <Setter Property="Background" Value="{StaticResource ElectricLimeBrush}"/>
        </Style>
    </Window.Styles>
</Window>
